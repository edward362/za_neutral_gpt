# ===========================================
# NeutralGPT Environment Variables
# ===========================================
# Copy this file to backend/.env and fill in your keys.
# You only need the key(s) for the provider(s) you want to use.

# --- LLM Provider API Keys ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# --- Default provider: openai | anthropic | google ---
DEFAULT_PROVIDER=openai

# --- Model overrides (optional) ---
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_MODEL=gemini-2.0-flash

# --- Backend server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (production Express server) ---
# PORT=3000
# API_URL=http://localhost:8000
